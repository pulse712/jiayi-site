# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env in the project root (next to docker-compose.yml)
# and fill in every value before running docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Strapi secrets ────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_NAME=jiayi
DATABASE_USERNAME=jiayi
DATABASE_PASSWORD=

# ── URLs ──────────────────────────────────────────────────────────────────────
SITE_URL=https://jiayi-tools.com
CMS_URL=https://cms.jiayi-tools.com

# ── Strapi API token (create in Strapi Admin → Settings → API Tokens) ─────────
# Set this AFTER first boot and first admin-user creation
STRAPI_API_TOKEN=
