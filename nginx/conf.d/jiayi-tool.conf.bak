# ─────────────────────────────────────────────────────────────────────────────
# jiayi-tools.com  →  Next.js frontend
# cms.jiayi-tools.com  →  Strapi CMS
#
# SSL certs are managed by Certbot (Let's Encrypt).
# ─────────────────────────────────────────────────────────────────────────────

# ── Redirect all HTTP → HTTPS ─────────────────────────────────────────────────
server {
    listen 80;
    server_name jiayi-tools.com www.jiayi-tools.com cms.jiayi-tools.com;

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect everything else to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# ── Main site — jiayi-tools.com ────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name jiayi-tools.com www.jiayi-tools.com;

    ssl_certificate     /etc/letsencrypt/live/jiayi-tools.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/jiayi-tools.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    # HSTS
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

    # Max upload size (for RFQ drawings)
    client_max_body_size 15M;

    # Next.js static assets — long cache
    location /_next/static/ {
        proxy_pass         http://frontend:3000;
        proxy_cache_valid  200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Public folder (robots.txt, favicon, etc.)
    location /robots.txt  { proxy_pass http://frontend:3000; }
    location /sitemap.xml { proxy_pass http://frontend:3000; }
    location /favicon.ico { proxy_pass http://frontend:3000; }

    # Everything else → Next.js
    location / {
        proxy_pass         http://frontend:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }
}

# ── Strapi CMS — cms.jiayi-tools.com ──────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name cms.jiayi-tools.com;

    ssl_certificate     /etc/letsencrypt/live/cms.jiayi-tools.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cms.jiayi-tools.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

    # Max upload size (product images)
    client_max_body_size 50M;

    # Strapi media uploads — serve with cache
    location /uploads/ {
        proxy_pass         http://strapi:1337;
        add_header Cache-Control "public, max-age=604800";
        proxy_cache_valid  200 7d;
    }

    # Strapi API + admin
    location / {
        proxy_pass         http://strapi:1337;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
