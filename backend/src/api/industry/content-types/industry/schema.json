{
  "kind": "collectionType",
  "collectionName": "industries",
  "info": {
    "singularName": "industry",
    "pluralName": "industries",
    "displayName": "Industry",
    "description": "Industry sectors served by JIAYI TOOL"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": { "localized": true }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "desc": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "details": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "applications": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "string",
      "required": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
