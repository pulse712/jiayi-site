{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product Info",
    "description": "Individual precision cutting tool"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": { "localized": true }
  },
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "spec": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "standard": {
      "type": "enumeration",
      "enum": [
        "SAE J1926",
        "ISO 6149",
        "Sun Hydraulics",
        "HydraForce",
        "Parker",
        "Danfoss",
        "Bosch Rexroth",
        "Eaton",
        "Other"
      ]
    },
    "material": {
      "type": "enumeration",
      "enum": ["Carbide", "HSS", "HSS-Co", "PCD", "PCBN", "Cermet", "CBN"]
    },
    "coating": {
      "type": "enumeration",
      "enum": ["TiAlN", "AlTiN", "TiCN", "DLC", "Diamond CVD", "Uncoated"]
    },
    "description": {
      "type": "blocks",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seoTitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seoDescription": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "technicalDrawing": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products",
      "required": true
    }
  }
}
