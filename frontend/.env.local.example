# Copy this file to .env.local and fill in the values

# Strapi API URL (use http://localhost:1337 for local dev)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API token (generate in Strapi Admin → Settings → API Tokens)
STRAPI_API_TOKEN=your_strapi_api_token_here

# Site URL (used for canonical links and OG tags)
NEXT_PUBLIC_SITE_URL=https://jiayi-tools.com
